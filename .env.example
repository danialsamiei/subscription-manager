# ==================== Orcest AI SSO (login.orcest.ai) ====================
# Enable SSO authentication (set to 'true' to require login)
SSO_ENABLED=true

# NextAuth.js configuration
NEXTAUTH_URL=https://subcorist.orcest.ai
NEXTAUTH_SECRET=your-secret-key-here

# Orcest SSO - uses LOGIN_SSO_URL from Render env group (orcest-ai-shared-apis)
# or falls back to default https://login.orcest.ai
LOGIN_SSO_URL=https://login.orcest.ai
ORCEST_SSO_CLIENT_ID=subcorist
ORCEST_SSO_CLIENT_SECRET=your-oidc-client-secret-here

# ==================== Orcest Odoo ERP (do.orcest.ai) ====================
ODOO_URL=https://do.orcest.ai
ODOO_DB=orcest

# ==================== API Keys (from Render env group: orcest-ai-shared-apis) ====================
# These are auto-synced to provider credentials on app init
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
HF_TOKEN=
